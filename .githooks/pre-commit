#!/bin/sh
# Auto-rebuild JSX before commit if source files changed.
# Runs from the repo root with explicit web/ paths so staging never depends on
# the current directory (an earlier version cd'd into web/ first, which made the
# `git add` cwd-fragile).

CHANGED=$(git diff --cached --name-only | grep -E "^web/(app|tweaks-panel)\.jsx$")
if [ -z "$CHANGED" ]; then
  exit 0
fi

echo "JSX changed — rebuilding..."

if command -v npx >/dev/null 2>&1; then
  ESBUILD="npx esbuild"
elif [ -x "$HOME/.bun/bin/bun" ]; then
  ESBUILD="$HOME/.bun/bin/bun x esbuild"
else
  echo "Error: esbuild not found. Install with: npm install -g esbuild"
  exit 1
fi

$ESBUILD web/app.jsx --jsx=transform --outfile=web/app.js --log-level=warning
$ESBUILD web/tweaks-panel.jsx --jsx=transform --outfile=web/tweaks-panel.js --log-level=warning

git add web/app.js web/tweaks-panel.js
echo "Done. Built files staged."
