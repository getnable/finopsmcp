#!/bin/sh
# Auto-rebuild JSX before commit if source files changed

CHANGED=$(git diff --cached --name-only | grep -E "^web/(app|tweaks-panel)\.jsx$")
if [ -z "$CHANGED" ]; then
  exit 0
fi

echo "JSX changed — rebuilding..."

cd web

if command -v npx >/dev/null 2>&1; then
  ESBUILD="npx esbuild"
elif command -v ~/.bun/bin/bun >/dev/null 2>&1; then
  ESBUILD="~/.bun/bin/bun x esbuild"
else
  echo "Error: esbuild not found. Install with: npm install -g esbuild"
  exit 1
fi

$ESBUILD app.jsx --jsx=transform --outfile=app.js --log-level=warning
$ESBUILD tweaks-panel.jsx --jsx=transform --outfile=tweaks-panel.js --log-level=warning

git add app.js tweaks-panel.js
echo "Done. Built files staged."
